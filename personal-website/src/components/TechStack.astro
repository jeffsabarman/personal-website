---
import ButtonLink from "./shared/ButtonLink.astro"
import SectionTitle from "./shared/SectionTitle.astro"
import colors from "tailwindcss/colors"

type Skill = {text: string, link: string}

const skills: {subsection: string, skillItems: Skill[]}[] = [
    {
        subsection: "Frontend", skillItems: [
            // {text: "JavaScript", link: "https://developer.mozilla.org/en-US/docs/Web/JavaScript"}, 
            {text: "React", link: "https://react.dev/"}, 
            {text: "TypeScript", link: "https://www.typescriptlang.org/"}, 
            {text: "Next.js", link: "https://nextjs.org/"}, 
        ]
    },
    {
        subsection: "AI", skillItems: [
            {text: "Python", link: "https://www.python.org/"}, 
            {text: "Pydantic AI", link: "https://pydantic.dev/"}, 
            {text: "MCP", link: "https://modelcontextprotocol.io/docs/getting-started/intro/"}, 
            // {text: "Prompt Engineering", link: "https://www.python.org/"}, 
        ]
    },
    {
        subsection: "Backend & Development", skillItems: [
            {text: "Node.js", link: "https://nodejs.org/en"},
            {text: "GraphQL", link: "https://graphql.org/"},
            {text: "MongoDB", link: "https://www.mongodb.com/"},
            {text: "Git", link: "https://git-scm.com/"},
            {text: "Docker", link: "https://www.docker.com/"},
            {text: "Playwright", link: "https://playwright.dev/"},
        ]
    },
]
---
<div class="flex-col space-y-10">
    <SectionTitle text="Tech Stack" />
    {
        skills.map(skill => (
                <div class="flex-col space-y-6">
            <p class="text-sm">
                {skill.subsection}
            </p>
            <div class="grid grid-cols-3 max-md:grid-cols-2 gap-[1rem]">
                {
                    skill.skillItems.map(skillItem => (
                        // <div class="box">
                        //     <p class="">{skill}</p>
                        // </div>
                        <ButtonLink link={skillItem.link} fullwidth>{skillItem.text}</ButtonLink>
                    ))
                }
            </div>
    </div>
            ))
        }
</div>
<style>
    .box {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1rem;
        /* border: 0.1rem solid theme('colors.default'); */
        background-color: theme('colors.dark-blue');
        border-radius: 0.2rem;
        color: white;
        /* margin-bottom: 1rem; */
    }
    .box:hover {
        /* background-color: theme('colors.dark-blue'); */
        cursor: pointer;
        /* color: white */
    }
</style>